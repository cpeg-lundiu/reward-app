{
    "name": "samchan/reward-app",
    "description": "A cute family rewards app: piggy-bank balances, star tasks, and reward claims for parents and children.",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "ext-pdo": "*",
        "slim/slim": "^4.12",
        "slim/psr7": "^1.6",
        "php-di/php-di": "^7.0",
        "slim/php-view": "^3.3",
        "vlucas/phpdotenv": "^5.6"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    }
}
